{
  "name": "tactic-boss-ai",
  "private": true,
  "version": "1.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "vite preview --host 0.0.0.0",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm run test && npm run build",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit:release": "node scripts/release-audit.mjs",
    "check:release": "npm run lint && npm run test && npm run build && npm run audit:release && npm run test:e2e",
    "check:launch": "node scripts/launch-readiness.mjs",
    "verify:live-supabase": "node scripts/live-supabase-verify.mjs",
    "configure:production": "node scripts/inject-production-config.mjs",
    "build:launch": "npm run configure:production && npm run check && npm run check:launch",
    "check:web-launch": "node scripts/web-launch-readiness.mjs",
    "build:web-launch": "vite build",
    "build:web": "vite build",
    "build:netlify": "vite build"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  },
  "description": "Football tactics platform with Community Lite, referrals, eFootball manager simulation, auto tactical board and AI coaching."
}